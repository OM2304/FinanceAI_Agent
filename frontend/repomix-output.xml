<file path="app/page.jsx">
'use client'

import { UploadComponent } from './components/UploadComponent';
import { ExpenseChart } from './components/ExpenseChart';
import { DeleteButton } from './components/DeleteButton';
import { AiAssistant } from './components/AiAssistant';
import { BackendCharts } from './components/BackendCharts';
import { fetchExpenses } from '../lib/api';
import { useEffect, useState, useCallback } from 'react'; // Added useCallback
import { useRouter } from 'next/navigation';

export default function Home() {
  const [expenses, setExpenses] = useState([]);
  const [backendConnected, setBackendConnected] = useState(true);
  const [loading, setLoading] = useState(true);
  const [activeTab, setActiveTab] = useState('overview');
  const router = useRouter();

  // Define the fetch function outside useEffect so we can pass it down
  const loadExpenses = useCallback(async () => {
    try {
      const token = localStorage.getItem('sb-token');
      if (!token) {
        // If no token, stop loading and let the useEffect handle redirect
        return;
      }

      const data = await fetchExpenses(token);
      setExpenses(data);
      setBackendConnected(true);
    } catch (error) {
      console.error("Failed to fetch expenses:", error);
      if (error.message === "Unauthorized") {
        localStorage.removeItem('sb-token');
        router.push('/login');
        return;
      }
      setBackendConnected(false);
    } finally {
      setLoading(false);
    }
  }, [router]);

  useEffect(() => {
    // Check authentication immediately
    const token = localStorage.getItem('sb-token');
    if (!token) {
      router.push('/login');
      return; 
    }

    // Call the fetch function
    loadExpenses();
  }, [router, loadExpenses]);

  // Pass loadExpenses to the UploadComponent as onUploadSuccess
  
  if (loading) {
    return (
      <div className="min-h-screen flex items-center justify-center bg-gray-50">
        <div className="text-center">
          <div className="animate-spin rounded-full h-12 w-12 border-b-2 border-blue-600 mx-auto"></div>
          <p className="mt-4 text-gray-600">Loading...</p>
        </div>
      </div>
    );
  }
  
  const totalAmount = expenses.reduce((sum, item) => sum + item.amount, 0);

  return (
    <main className="min-h-screen bg-gray-50">
      <div className="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
        
        {/* Header Section */}
        <header className="mb-8">
          <div className="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4">
